# Build context hygiene — keeps the image lean and prevents secrets/local
# state from baking into a layer. Runtime mounts (docker-compose's bind
# mount of `.:/app`) are unaffected by this list.

# VCS + IDE
.git
.gitignore
.gitattributes
.idea
.vscode
.DS_Store

# Python local state
.venv
venv
env
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache

# Node / web local state (defensive — none today, but keeps the door shut)
node_modules

# Secrets — never bake these into a layer. Compose mounts the host .env
# at runtime, and `docker run --env-file` injects values without copying
# the file in.
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# Generated runtime artifacts — should be regenerated by the container,
# not inherited from the host.
Task\ 1\ Multi-Source\ Scraper/output/.cache
Task\ 1\ Multi-Source\ Scraper/output/*.json

# Claude Code / planning local artifacts (committed to the repo but not
# needed inside the runtime image).
.claude
plan.txt

# Docs that don't belong in the running image — keep the build context
# small. README.md / REPORT.md still ship for grading convenience.
trustcrawler.egg-info
